// Id_quantique clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace id_quantique {

    entity KeySession {
        id: string @unique
        aliceNodeId: string
        bobNodeId: string
        protocol: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Node {
        id: string @unique
        name: string
        location: string
        role: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Channel {
        id: string @unique
        sessionId: string
        medium: string
        lossDb: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Key {
        id: string @unique
        sessionId: string
        lengthBits: integer
        qber: float
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Protocol {
        id: string @unique
        name: string
        family: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Alarm {
        id: string @unique
        nodeId: string
        type: string
        raisedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
